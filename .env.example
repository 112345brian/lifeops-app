# Copy to .env and fill in. .env is gitignored — never commit it.

# FlowSavvy — get the base URL + a token from my.flowsavvy.app/api/docs
FLOWSAVVY_BASE_URL=https://my.flowsavvy.app/api
FLOWSAVVY_TOKEN=

# YNAB — Account Settings > Developer Settings > New Token
YNAB_TOKEN=
YNAB_BUDGET=last-used

# Anthropic — for the judgment-call slivers only
ANTHROPIC_API_KEY=
JUDGE_MODEL=claude-haiku-4-5-20251001

# ntfy topics (pick unguessable names; subscribe to the alerts one on your phone)
NTFY_SIGNAL_TOPIC=
NTFY_ALERTS_TOPIC=

# FlowSavvy ids (already known from your account)
LIST_PERSONAL=6784
LIST_COURSE=147765
SH_EVENINGS=427991
SH_PERSONAL=427988

# Personal identifiers
PARTNER_NAME=
PARTNER_TASK=
PARTNER_SIGNAL=
FRIENDS_TASK=Friends
FRIEND_NAMES=
SOCIAL_CAL=
EVENT_CALS=
# Comma-separated calendar event titles you already know are routine --
# see notable_events.py's docstring (signal 2).
ROUTINE_EVENT_TITLES=
DISCRETIONARY=Shopping,Entertainment,Eating Out,Shows,Splurge
OUTING_COSTS=concert:40,party:35,date:50,friends:35
YNAB_NO_ASSIGN=Savings,Emergency Fund,Stocks
YNAB_COVER_ORDER=Shopping,Entertainment,Eating Out,Shows,Splurge
PRIO_MEAL=normal
PRIO_SOCIAL_PLAN=normal
PRIO_SOCIAL_PROPOSED=low
PROPOSE_AHEAD_DAYS=21
PLAN_LEAD_DAYS=14
SLEEP_OK_MIN=330
HEARTBEAT_URL=

# Web control panel — calendar id for UI-created "block this day" busy events,
# and an optional shared secret if you expose the panel over Tailscale
# (open once as /?token=<secret>; leave WEB_TOKEN unset for localhost-only use)
BLOCK_CAL=
WEB_TOKEN=
# Your Tailscale HTTPS hostname (e.g. https://mypc.tailxxxx.ts.net) — lets
# notifications deep-link straight into the panel. Blank = no tap-through link.
PANEL_URL=

# Canvas LMS coursework sync — CANVAS_TOKEN if your school allows self-service
# API tokens (Canvas: Account > Settings > New access token). If it doesn't
# (e.g. JHU), leave this blank — lifeops falls back to a browser session via
# scripts/canvas_login.py automatically; no cookie or extra config needed.
CANVAS_TOKEN=
CANVAS_BASE_URL=https://jhu.instructure.com
CANVAS_COURSE_ID=
SH_COURSE=

# Weather (NOAA/NWS api.weather.gov — free, no API key). Blank = feature off.
WEATHER_LAT=
WEATHER_LON=
WEATHER_USER_AGENT=lifeops-app (personal use)
