<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_preview_bg"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_preview_tile_bg"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal"
            android:text="@string/widget_preview_money_label"
            android:textColor="#B8B5C0"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.5"
            android:gravity="center"
            android:text="@string/widget_preview_money"
            android:textColor="#E4E2E9"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:background="@drawable/widget_preview_badge_bg"
            android:gravity="center"
            android:text="@string/widget_preview_money_status"
            android:textColor="#E4E2E9"
            android:textSize="7sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
