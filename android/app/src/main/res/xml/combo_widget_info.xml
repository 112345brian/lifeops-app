<?xml version="1.0" encoding="utf-8"?>
<!-- "LifeOps Combo": a 4x3 widget instance whose left 2x3 half stacks
     [money|social] (2-wide) over coursework (full-width) over weather
     (full-width), and whose right 2x3 half is notable events: see
     ComboGridContent in BriefingWidget.kt. The point of this preset is
     specifically to avoid the launcher's own inter-widget grid gap that
     five separately-placed single-stat widgets would have between them, so
     minWidth/minHeight are deliberately set inside the "70 x n - 30"
     formula's tiers (see android/CLAUDE.md): minWidth stays in the n=4
     tier (250dp to 319dp) same as before (280dp gives comfortable margin
     under the 320dp n=5 ceiling), but minHeight moved from the n=2 tier to
     the n=3 tier (180dp to 249dp): 220dp, safely under the 250dp n=4
     ceiling. When the grid still crammed 3 stat tiles across one 2-wide
     row, each tile only got ~1/3 of the left half's width; splitting
     coursework onto its own full-width row instead needed a 3rd row of
     vertical room to keep every row's height (and therefore its
     SoloStatCard label/value/status-bar text) from shrinking below what's
     legible (confirmed 2026-07-15: "the text is small... it should be
     LEGIBLE"). Real per-metric widgets consistently reduce item count
     rather than shrinking text to force more into the same row (Android's
     own smallest widget shows exactly one metric, iOS's smallest shows
     two): this follows the same principle by moving the 3rd stat to its
     own row instead of keeping 3 abreast at a shrunk size. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="280dp"
    android:minHeight="220dp"
    android:minResizeWidth="280dp"
    android:minResizeHeight="220dp"
    android:maxResizeWidth="400dp"
    android:maxResizeHeight="320dp"
    android:targetCellWidth="4"
    android:targetCellHeight="3"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:updatePeriodMillis="1800000"
    android:description="@string/widget_description_combo"
    android:initialLayout="@layout/widget_loading"
    android:previewLayout="@layout/widget_preview_combo"
    android:configure="com.lifeops.briefing.WidgetConfigActivity"
    android:widgetFeatures="reconfigurable" />
