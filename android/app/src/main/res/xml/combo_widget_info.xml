<?xml version="1.0" encoding="utf-8"?>
<!-- "LifeOps Combo": one resizable dynamic widget, not a separate provider
     for every launcher span. minWidth/minHeight sit at the 2-cell tier
     (110dp == 70*2-30; see android/CLAUDE.md) so launchers can offer 2x2,
     while targetCellWidth/Height keep the default placement at a roomy 4x2.
     BriefingWidget.kt reads LocalSize.current with SizeMode.Exact and picks
     a layout for 2x2, 3x2, 4x2, or taller placements, reducing the number
     of visible cells as space tightens instead of shrinking text until it
     clips. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:minResizeWidth="110dp"
    android:minResizeHeight="110dp"
    android:maxResizeWidth="400dp"
    android:maxResizeHeight="320dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:updatePeriodMillis="1800000"
    android:description="@string/widget_description_combo"
    android:initialLayout="@layout/widget_loading"
    android:previewLayout="@layout/widget_preview_combo"
    android:configure="com.lifeops.briefing.WidgetConfigActivity"
    android:widgetFeatures="reconfigurable" />
