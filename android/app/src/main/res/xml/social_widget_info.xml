<?xml version="1.0" encoding="utf-8"?>
<!-- Single-stat preset (social only). SocialSection now stacks the
     partner/friends chips vertically for this preset (see [stacked] in
     BriefingWidget.kt), each chip using tighter font sizes/padding than the
     default StatTile, so both fit within the same true 2x1 (110dp x 56dp)
     footprint every other single-stat preset uses:matching weather's
     footprint too, so the two line up when placed together (confirmed
     2026-07-13: "ideally we would have the weather 2x1, then the
     friends/social 2x1"). -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="56dp"
    android:minResizeWidth="110dp"
    android:minResizeHeight="56dp"
    android:maxResizeWidth="280dp"
    android:maxResizeHeight="250dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_loading"
    android:previewLayout="@layout/widget_loading"
    android:configure="com.lifeops.briefing.WidgetConfigActivity"
    android:widgetFeatures="reconfigurable" />
