<?xml version="1.0" encoding="utf-8"?>
<!-- Single-stat preset (weather only). Weather keeps a true 2x1 footprint
     because current temp + condition/high/low need horizontal room. COMPACT_WEATHER_*
     in BriefingWidget.kt already fits this width without clipping; the
     one thing that still needed tuning was the condition text label
     itself, nudged down a point (confirmed 2026-07-13: "it was literally
     fine except for that"). maxResizeWidth/Height still let it grow into
     the full card if the user drags it bigger. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="56dp"
    android:minResizeWidth="110dp"
    android:minResizeHeight="56dp"
    android:maxResizeWidth="320dp"
    android:maxResizeHeight="250dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:updatePeriodMillis="1800000"
    android:description="@string/widget_description_weather"
    android:initialLayout="@layout/widget_loading"
    android:previewLayout="@layout/widget_preview_weather"
    android:configure="com.lifeops.briefing.WidgetConfigActivity"
    android:widgetFeatures="reconfigurable" />
